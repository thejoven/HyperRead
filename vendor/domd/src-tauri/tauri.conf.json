{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DOMD",
  "version": "0.1.3",
  "identifier": "com.domd.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DOMD",
        "url": "/editor",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown File",
        "role": "Editor"
      }
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Jintao Wang (G3TUSL5X84)"
    }
  },
  "plugins": {}
}
